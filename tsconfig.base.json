{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@org/backend/app/*": [
        "./apps/backend/src/app/*"
      ],
      "@org/voting-contracts": [
        "./libs/shared/voting-contracts/src/index.ts"
      ],
      "@cacic-fct/form-contracts": [
        "./libs/shared/form-contracts/src/index.ts"
      ],
      "@cacic-fct/account-manager-m2m-contracts": [
        "../cacic-account-manager/dist/libs/m2m-contracts/index.d.ts"
      ],
      "@cacic-fct/event-manager-m2m-contracts": [
        "../fct-app/dist/libs/event-manager-m2m-contracts/index.d.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
