{
  "name": "form-contracts",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/form-contracts/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:data", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/shared/form-contracts"],
      "options": {
        "cwd": "libs/shared/form-contracts",
        "command": "rm -rf ../../../dist/libs/shared/form-contracts && bun run tsc -p tsconfig.lib.json && cp package.json README.md ../../../dist/libs/shared/form-contracts/"
      }
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "dist/libs/shared/form-contracts",
        "command": "bun publish --access public --registry https://registry.npmjs.org"
      }
    }
  }
}
